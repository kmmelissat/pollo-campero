PORT=3002
NODE_ENV=development
MENU_SERVICE_URL=http://localhost:3001
RABBITMQ_URL=amqp://guest:guest@localhost:5672
# Prisma usa WRITE_DB_URL (ver prisma/schema.prisma). DATABASE_URL no es obligatorio.
WRITE_DB_URL=postgresql://pollos:pollos@localhost:5432/orders
# Réplica u otra instancia (puerto distinto si usas Compose con dos Postgres)
READ_DB_URL=postgresql://pollos:pollos@localhost:5433/orders
# Solo en Docker/K8s con dos Postgres y primaria en wal_level=logical (ver README)
# SETUP_LOGICAL_REPLICATION=true
