generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("WRITE_DB_URL")
}

model Order {
  id           String   @id @default(uuid())
  customerName String
  items        Json
  total        Decimal  @db.Decimal(12, 2)
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("orders")
}
